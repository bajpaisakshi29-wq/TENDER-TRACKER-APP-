<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<meta name="theme-color" content="#0D3E4D">
<title>Order tracker — AGS Safety</title>
<link rel="manifest" id="pwaManifestLink">
<!-- Manifest is generated at runtime below (see registerPWA()) so the app icon can reuse the
     embedded AGS shield artwork without needing a separately hosted icon file. -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
  :root{
    --cream:#F3EDE3;
    --navy:#0D3E4D;
    --navy-dark-bg:#0A2530;
    --red:#B62E47;
    --red-pale:#F5DEE3;
    --orange:#864A1C;
    --orange-pale:#F1E1CE;
    --green:#4A5A30;
    --green-pale:#E4E7DA;
    --card-light:#FFFFFF;
    --card-dark:#0F3040;
    --text-light:#1C2A2E;
    --text-dark:#F3EDE3;
    --border-light: rgba(13,62,77,0.12);
    --border-dark: rgba(243,237,227,0.14);
  }
  *{box-sizing:border-box;}
  body{margin:0;font-family:'Inter',sans-serif;background:var(--cream);color:var(--text-light);transition:background .2s,color .2s;}
  body.dark{background:var(--navy-dark-bg);color:var(--text-dark);}
  h1,h2,h3,.serif{font-family:'Fraunces',serif;}
  button{font-family:'Inter',sans-serif;cursor:pointer;}
  .app{min-height:100vh;display:flex;flex-direction:column;}
  /* Header */
  header.topbar{
    display:flex;align-items:center;justify-content:space-between;
    padding:14px 24px;border-bottom:1px solid var(--border-light);
  }
  body.dark header.topbar{border-bottom:1px solid var(--border-dark);}
  .brand{display:flex;align-items:center;gap:12px;}
  .brand img{height:42px;width:auto;display:block;}
  body.dark .brand img.logo-invert{filter:invert(1) brightness(1.6);}
  .brand .word{display:flex;flex-direction:column;line-height:1.1;}
  .brand .word .name{font-family:'Fraunces',serif;font-weight:600;font-size:19px;letter-spacing:.5px;}
  .brand .word .tag{font-size:11px;opacity:.65;letter-spacing:.3px;}
  .top-right{display:flex;align-items:center;gap:14px;}
  .icon-btn{
    background:transparent;border:1px solid var(--border-light);border-radius:10px;
    width:36px;height:36px;display:flex;align-items:center;justify-content:center;font-size:16px;
    color:inherit;
  }
  body.dark .icon-btn{border-color:var(--border-dark);}
  .avatar{
    width:34px;height:34px;border-radius:50%;background:var(--navy);color:var(--cream);
    display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:600;
    font-family:'Fraunces',serif;
  }
  .nav-tabs{display:flex;gap:6px;padding:0 24px;border-bottom:1px solid var(--border-light);}
  body.dark .nav-tabs{border-bottom:1px solid var(--border-dark);}
  .nav-tabs button{
    background:transparent;border:none;padding:12px 14px;font-size:13.5px;color:inherit;opacity:.6;
    border-bottom:2px solid transparent;
  }
  .nav-tabs button.active{opacity:1;border-bottom:2px solid var(--navy);font-weight:600;}
  body.dark .nav-tabs button.active{border-bottom:2px solid var(--cream);}
  main{flex:1;padding:28px 24px 60px;max-width:1180px;margin:0 auto;width:100%;}

  /* Buttons */
  .btn{
    border:none;border-radius:10px;padding:10px 18px;font-size:13.5px;font-weight:600;
    display:inline-flex;align-items:center;gap:8px;
  }
  .btn-primary{background:var(--navy);color:var(--cream);}
  body.dark .btn-primary{background:var(--cream);color:var(--navy-dark-bg);}
  .btn-ghost{background:transparent;border:1px solid var(--border-light);color:inherit;}
  body.dark .btn-ghost{border-color:var(--border-dark);}
  .btn-danger{background:var(--red);color:#fff;}
  .btn:disabled{opacity:.4;cursor:not-allowed;}
  .btn-sm{padding:7px 12px;font-size:12.5px;border-radius:8px;}

  /* Cards */
  .card{background:var(--card-light);border-radius:12px;padding:20px;border:1px solid var(--border-light);}
  body.dark .card{background:var(--card-dark);border-color:var(--border-dark);}

  /* Badges */
  .badge{display:inline-flex;align-items:center;padding:4px 10px;border-radius:20px;font-size:11px;font-weight:600;letter-spacing:.4px;color:#fff;}
  .badge.overdue{background:var(--red);}
  .badge.due-soon{background:var(--orange);}
  .badge.on-track{background:var(--green);}
  .badge.archived{background:#7a7a7a;}
  .tint.overdue{background:var(--red-pale);color:var(--red);}
  .tint.due-soon{background:var(--orange-pale);color:var(--orange);}
  .tint.on-track{background:var(--green-pale);color:var(--green);}

  /* Forms */
  input[type=text],input[type=email],input[type=password],input[type=date],textarea,select{
    width:100%;padding:10px 12px;border-radius:9px;border:1px solid var(--border-light);
    background:transparent;color:inherit;font-family:'Inter',sans-serif;font-size:13.5px;
  }
  body.dark input,body.dark textarea,body.dark select{border-color:var(--border-dark);}
  label.field-label{font-size:12px;opacity:.65;display:block;margin-bottom:6px;letter-spacing:.2px;}
  .field{margin-bottom:14px;}

  /* Auth screen */
  .auth-wrap{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;}
  .auth-card{width:100%;max-width:380px;}
  .auth-card img{height:64px;display:block;margin:0 auto 18px;}
  .auth-card h1{text-align:center;font-size:24px;margin:0 0 4px;}
  .auth-card .sub{text-align:center;font-size:12.5px;opacity:.6;margin-bottom:24px;}
  .auth-toggle{display:flex;gap:6px;justify-content:center;margin-top:16px;font-size:12.5px;}
  .auth-toggle a{color:var(--navy);font-weight:600;cursor:pointer;text-decoration:underline;}
  body.dark .auth-toggle a{color:var(--cream);}
  .error-text{color:var(--red);font-size:12.5px;margin-top:8px;}

  /* Waiting room */
  .waiting-wrap{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:20px;}
  .pulse-dot{width:14px;height:14px;border-radius:50%;background:var(--navy);margin:0 6px;display:inline-block;animation:pulse 1.4s infinite ease-in-out;}
  body.dark .pulse-dot{background:var(--cream);}
  .pulse-dot:nth-child(2){animation-delay:.2s;}
  .pulse-dot:nth-child(3){animation-delay:.4s;}
  @keyframes pulse{0%,80%,100%{transform:scale(.6);opacity:.4;}40%{transform:scale(1);opacity:1;}}

  /* Dashboard grid */
  .dash-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;flex-wrap:wrap;gap:10px;}
  .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:16px;}
  .tender-card{padding:18px;border-radius:12px;background:var(--card-light);border:1px solid var(--border-light);cursor:pointer;position:relative;}
  body.dark .tender-card{background:var(--card-dark);border-color:var(--border-dark);}
  .tender-card.overdue-flag{border-left:4px solid var(--red);}
  .tender-card .tname{font-family:'Fraunces',serif;font-size:17px;margin:0 0 4px;}
  .tender-card .tdate{font-size:12px;opacity:.6;margin-bottom:12px;}
  .stage-bar{display:flex;gap:3px;margin-top:12px;}
  .stage-seg{flex:1;height:5px;border-radius:3px;background:var(--border-light);}
  body.dark .stage-seg{background:var(--border-dark);}
  .stage-seg.done{background:var(--navy);}
  body.dark .stage-seg.done{background:var(--cream);}

  .empty-state{text-align:center;padding:60px 20px;opacity:.85;}
  .empty-state .emoji{font-size:38px;margin-bottom:10px;}
  .empty-state h3{margin:0 0 6px;}
  .empty-state p{font-size:13.5px;opacity:.65;margin:0 0 18px;}

  /* Detail page */
  .stage-tracker{display:flex;gap:4px;margin-bottom:24px;overflow-x:auto;padding-bottom:4px;}
  .stage-step{flex:1;min-width:84px;text-align:center;font-size:10.5px;padding:8px 4px;border-radius:8px;background:var(--border-light);opacity:.55;}
  body.dark .stage-step{background:var(--border-dark);}
  .stage-step.current{opacity:1;font-weight:700;}
  .status-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:10px;margin-bottom:24px;}
  .status-card{border-radius:10px;padding:12px;font-size:12px;}
  .tabs{display:flex;gap:4px;border-bottom:1px solid var(--border-light);margin-bottom:20px;}
  body.dark .tabs{border-bottom:1px solid var(--border-dark);}
  .tabs button{background:none;border:none;padding:10px 14px;font-size:13px;opacity:.55;color:inherit;border-bottom:2px solid transparent;}
  .tabs button.active{opacity:1;font-weight:600;border-bottom:2px solid var(--navy);}
  body.dark .tabs button.active{border-bottom:2px solid var(--cream);}
  .spec-row{display:flex;gap:10px;align-items:center;padding:8px 0;border-bottom:1px solid var(--border-light);}
  body.dark .spec-row{border-bottom:1px solid var(--border-dark);}
  .radio-group{display:flex;gap:10px;flex-wrap:wrap;}
  .radio-opt{border:1px solid var(--border-light);padding:9px 14px;border-radius:9px;font-size:13px;cursor:pointer;}
  body.dark .radio-opt{border-color:var(--border-dark);}
  .radio-opt.sel{background:var(--navy);color:var(--cream);border-color:var(--navy);}
  body.dark .radio-opt.sel{background:var(--cream);color:var(--navy-dark-bg);border-color:var(--cream);}
  .checkline{display:flex;align-items:center;gap:10px;padding:8px 0;font-size:13.5px;}
  .back-link{font-size:13px;opacity:.7;cursor:pointer;display:inline-flex;align-items:center;gap:4px;margin-bottom:16px;}

  table.admin-table{width:100%;border-collapse:collapse;font-size:13.5px;}
  table.admin-table th{text-align:left;font-size:11px;opacity:.55;padding:8px 10px;text-transform:uppercase;letter-spacing:.4px;}
  table.admin-table td{padding:10px;border-top:1px solid var(--border-light);}
  body.dark table.admin-table td{border-top:1px solid var(--border-dark);}
  .role-pill{font-size:10.5px;padding:3px 9px;border-radius:12px;background:var(--border-light);}
  body.dark .role-pill{background:var(--border-dark);}
  .toast{
    position:fixed;bottom:22px;left:50%;transform:translateX(-50%);
    background:var(--navy);color:var(--cream);padding:10px 18px;border-radius:10px;font-size:13px;
    opacity:0;transition:opacity .25s;pointer-events:none;z-index:999;
  }
  body.dark .toast{background:var(--cream);color:var(--navy-dark-bg);}
  .toast.show{opacity:1;}

  /* Documents */
  .doc-row{display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid var(--border-light);}
  body.dark .doc-row{border-bottom:1px solid var(--border-dark);}
  .doc-row:last-child{border-bottom:none;}
  .doc-info{flex:1;}
  .doc-name{font-weight:600;font-size:13.5px;}
  .doc-meta{font-size:11.5px;opacity:.6;margin-top:2px;}
  .doc-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
  .doc-dot.pending{background:var(--orange);}
  .doc-dot.uploaded{background:var(--green);}
  .file-input-label{border:1px solid var(--border-light);border-radius:8px;padding:7px 12px;font-size:12.5px;cursor:pointer;display:inline-block;}
  body.dark .file-input-label{border-color:var(--border-dark);}

  /* Chat */
  .chat-list{display:flex;flex-direction:column;gap:14px;max-height:420px;overflow-y:auto;padding:4px 2px 12px;}
  .chat-msg{display:flex;gap:10px;}
  .chat-msg .avatar{width:28px;height:28px;font-size:11px;flex-shrink:0;}
  .chat-bubble{background:var(--border-light);border-radius:12px;padding:9px 13px;font-size:13.5px;max-width:420px;}
  body.dark .chat-bubble{background:var(--border-dark);}
  .chat-meta{font-size:11px;opacity:.55;margin-bottom:3px;}
  .chat-bubble img{max-width:220px;border-radius:8px;margin-top:6px;display:block;}
  .chat-mention{color:var(--navy);font-weight:600;}
  body.dark .chat-mention{color:var(--cream);}
  .chat-reactions{display:flex;gap:5px;margin-top:6px;flex-wrap:wrap;}
  .reaction-pill{font-size:11px;border:1px solid var(--border-light);border-radius:10px;padding:1px 7px;cursor:pointer;}
  body.dark .reaction-pill{border-color:var(--border-dark);}
  .reaction-pill.mine{background:var(--navy);color:var(--cream);border-color:var(--navy);}
  .chat-input-row{display:flex;gap:8px;margin-top:12px;align-items:flex-end;}
  .mention-menu{position:absolute;background:var(--card-light);border:1px solid var(--border-light);border-radius:8px;padding:4px;box-shadow:0 4px 14px rgba(0,0,0,.12);z-index:20;}
  body.dark .mention-menu{background:var(--card-dark);border-color:var(--border-dark);}
  .mention-item{padding:6px 10px;font-size:13px;border-radius:6px;cursor:pointer;}
  .mention-item:hover{background:var(--border-light);}
  body.dark .mention-item:hover{background:var(--border-dark);}

  /* History */
  .hist-row{padding:9px 0;border-bottom:1px solid var(--border-light);font-size:13px;}
  body.dark .hist-row{border-bottom:1px solid var(--border-dark);}
  .hist-time{opacity:.55;font-size:11.5px;}

  /* Personal space */
  .todo-row{display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid var(--border-light);}
  body.dark .todo-row{border-bottom:1px solid var(--border-dark);}
  .todo-row.done .todo-text{text-decoration:line-through;opacity:.5;}
  .todo-text{flex:1;font-size:13.5px;}
  .toggle-row{display:flex;align-items:center;justify-content:space-between;padding:10px 0;font-size:13.5px;}

  /* Quote widget */
  .quote-line{font-family:'Fraunces',serif;font-style:italic;font-size:11.5px;opacity:.65;cursor:pointer;max-width:220px;
    overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
  .quote-popover{
    position:absolute;top:56px;right:24px;width:300px;background:var(--card-light);border:1px solid var(--border-light);
    border-radius:12px;padding:18px;box-shadow:0 10px 30px rgba(0,0,0,.15);z-index:50;
  }
  body.dark .quote-popover{background:var(--card-dark);border-color:var(--border-dark);}
  .quote-popover .verse{font-family:'Fraunces',serif;font-style:italic;font-size:14.5px;margin-bottom:10px;line-height:1.5;}
  .quote-popover .meaning{font-size:12.5px;opacity:.75;margin-bottom:12px;line-height:1.5;}
  .bookmark-btn{background:none;border:none;font-size:16px;cursor:pointer;color:inherit;}

  /* Notification bell */
  .bell-wrap{position:relative;}
  .bell-dot{position:absolute;top:2px;right:2px;width:8px;height:8px;border-radius:50%;background:var(--red);border:2px solid var(--cream);}
  body.dark .bell-dot{border-color:var(--navy-dark-bg);}
  .bell-dropdown{position:absolute;top:44px;right:0;width:340px;max-height:420px;overflow-y:auto;background:var(--card-light);
    border:1px solid var(--border-light);border-radius:12px;box-shadow:0 10px 30px rgba(0,0,0,.18);z-index:60;padding:8px;}
  body.dark .bell-dropdown{background:var(--card-dark);border-color:var(--border-dark);}
  .reminder-item{padding:10px;border-radius:9px;border:1px solid var(--border-light);margin-bottom:7px;font-size:12.5px;}
  body.dark .reminder-item{border-color:var(--border-dark);}
  .reminder-item.escalated{border-color:var(--red);background:var(--red-pale);}
  body.dark .reminder-item.escalated{background:rgba(182,46,71,.18);}
  .reminder-title{font-weight:600;margin-bottom:2px;}
  .reminder-sub{opacity:.65;font-size:11.5px;margin-bottom:8px;}
  .reminder-actions{display:flex;gap:5px;flex-wrap:wrap;}
  .snooze-btn{font-size:11px;padding:4px 8px;border-radius:7px;border:1px solid var(--border-light);background:transparent;color:inherit;cursor:pointer;}
  body.dark .snooze-btn{border-color:var(--border-dark);}
  .bell-empty{padding:26px 10px;text-align:center;opacity:.6;font-size:12.5px;}

  /* Offline banner */
  .offline-banner{background:var(--orange);color:#fff;text-align:center;padding:6px;font-size:12.5px;font-weight:600;letter-spacing:.2px;}
  .synced-banner{background:var(--green);color:#fff;text-align:center;padding:6px;font-size:12.5px;font-weight:600;}

  /* Onboarding modal */
  .modal-overlay{position:fixed;inset:0;background:rgba(13,62,77,.55);display:flex;align-items:center;justify-content:center;z-index:100;padding:20px;}
  .onboard-card{background:var(--card-light);border-radius:16px;padding:32px;max-width:420px;width:100%;text-align:center;}
  body.dark .onboard-card{background:var(--card-dark);}
  .onboard-emoji{font-size:44px;margin-bottom:14px;}
  .onboard-dots{display:flex;justify-content:center;gap:6px;margin:18px 0;}
  .onboard-dot{width:7px;height:7px;border-radius:50%;background:var(--border-light);}
  .onboard-dot.active{background:var(--navy);}
  body.dark .onboard-dot.active{background:var(--cream);}

  /* AI insights */
  .ai-insight-btn{font-size:11.5px;margin-top:6px;}
  .insight-panel{margin-top:10px;padding:12px;border-radius:10px;background:var(--border-light);font-size:12.5px;}
  body.dark .insight-panel{background:var(--border-dark);}
  .insight-summary{margin-bottom:10px;line-height:1.5;}
  .highlight-chip{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:14px;font-size:11px;
    font-weight:600;cursor:pointer;margin:3px 4px 3px 0;color:#fff;}
  .highlight-chip.high{background:var(--red);}
  .highlight-chip.medium{background:var(--orange);}
  .highlight-chip.low{background:var(--green);}
  .highlight-detail{margin-top:6px;padding:8px 10px;border-radius:8px;background:var(--card-light);font-size:12px;display:none;}
  body.dark .highlight-detail{background:var(--card-dark);}
  .highlight-detail.open{display:block;}

  /* Export buttons */
  .detail-header-actions{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:10px;}
</style>
</head>
