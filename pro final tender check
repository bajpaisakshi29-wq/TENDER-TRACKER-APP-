/* ============ STATUS COMPUTATION ============ */
function daysBetween(a,b){ return Math.floor((b-a)/(1000*60*60*24)); }

function computeStatus(t){
  if(t.archived) return 'archived';
  const now = new Date();
  const enteredAt = new Date(t.stageEnteredAt || t.createdAt);
  const daysInStage = daysBetween(enteredAt, now);
  if(t.currentStage===6 && t.dispatchDate){ // pre-dispatch: base on dispatch date
    const dd = new Date(t.dispatchDate);
    const daysLeft = daysBetween(now, dd);
    if(daysLeft < 0) return 'overdue';
    if(daysLeft <= 5) return 'due-soon';
    return 'on-track';
  }
  if(daysInStage > 14) return 'overdue';
  if(daysInStage >= 7) return 'due-soon';
  return 'on-track';
}

function statusLabel(s){
  return {overdue:'Overdue','due-soon':'Due soon','on-track':'On track',archived:'Archived'}[s];
}

