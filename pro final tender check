function chatMsgHtml(m){
  const initials = m.userName.split(' ').map(p=>p[0]).slice(0,2).join('').toUpperCase();
  const textHtml = escapeHtml(m.text).replace(/@([A-Za-z ]+)\b/g, (full,name)=>`<span class="chat-mention">@${name}</span>`);
  const myReaction = (m.reactions&&m.reactions['👍']||[]).includes(state.currentUser.id);
  const count = (m.reactions&&m.reactions['👍']||[]).length;
  return `<div class="chat-msg">
    <div class="avatar">${initials}</div>
    <div>
      <div class="chat-meta">${escapeHtml(m.userName)} · ${formatDateTime(m.timestamp)}</div>
      <div class="chat-bubble">${textHtml}${m.imageDataUrl?`<img src="${m.imageDataUrl}">`:''}</div>
      <div class="chat-reactions">
        <span class="reaction-pill ${myReaction?'mine':''}" data-react="${m.id}">👍 ${count>0?count:''}</span>
      </div>
    </div>
  </div>`;
}
function bindChat(t){
  const list = document.getElementById('chatList');
  if(list) list.scrollTop = list.scrollHeight;
  const input = document.getElementById('chatInput');
  const menu = document.getElementById('mentionMenu');
  const approvedUsers = state.users.filter(u=>u.status==='approved' && u.id!==state.currentUser.id);

  input.oninput = ()=>{
    const val = input.value;
    const atIdx = val.lastIndexOf('@');
    if(atIdx>=0 && (atIdx===0 || val[atIdx-1]===' ')){
      const q = val.slice(atIdx+1).toLowerCase();
      const matches = approvedUsers.filter(u=>u.name.toLowerCase().startsWith(q));
      if(matches.length && q.length<20){
        menu.innerHTML = `<div class="mention-menu">${matches.map(u=>`<div class="mention-item" data-mname="${escapeHtml(u.name)}">${escapeHtml(u.name)}</div>`).join('')}</div>`;
        menu.querySelectorAll('[data-mname]').forEach(el=>{
          el.onclick = ()=>{
            input.value = val.slice(0,atIdx) + '@'+el.dataset.mname+' ';
            menu.innerHTML=''; input.focus();
          };
        });
        return;
      }
    }
    menu.innerHTML='';
  };

  document.getElementById('sendChatBtn').onclick = async ()=>{
    const text = input.value.trim();
    const file = document.getElementById('chatImgInput').files[0];
    if(!text && !file) return;
    let imageDataUrl = null;
    if(file){ toast('Compressing image…'); imageDataUrl = await compressImage(file); }
    const msg = {
      id: uid(), userId: state.currentUser.id, userName: state.currentUser.name,
      text, imageDataUrl, timestamp: new Date().toISOString(), reactions:{}
    };
    t.chatMessages = t.chatMessages || [];
    t.chatMessages.push(msg);
    await saveTender(t);
    input.value=''; document.getElementById('chatImgInput').value='';
    render();
  };
  document.querySelectorAll('[data-react]').forEach(el=>{
    el.onclick = async ()=>{
      const msg = t.chatMessages.find(m=>m.id===el.dataset.react);
      msg.reactions = msg.reactions || {};
      msg.reactions['👍'] = msg.reactions['👍'] || [];
      const uidx = msg.reactions['👍'].indexOf(state.currentUser.id);
      if(uidx>=0) msg.reactions['👍'].splice(uidx,1); else msg.reactions['👍'].push(state.currentUser.id);
      await saveTender(t); render();
    };
  });

  clearTimeout(chatPollTimer);
  chatPollTimer = setTimeout(async ()=>{
    if(state.view!=='detail' || state.activeTab!=='chat') return;
    const { data: fresh } = await sb.from('tenders').select('*').eq('id', t.id).single();
    if(fresh){
      const freshTender = { ...fresh.data, id: fresh.id, name: fresh.name, archived: fresh.archived, createdAt: fresh.created_at,
        history: fresh.data.history||[], documents: fresh.data.documents||{}, chatMessages: fresh.data.chatMessages||[] };
      if(JSON.stringify(freshTender.chatMessages)!==JSON.stringify(t.chatMessages)){
        const idx = state.tenders.findIndex(x=>x.id===t.id);
        if(idx>=0) state.tenders[idx] = freshTender;
        render();
        return;
      }
    }
    bindChat(t);
  }, 6000);
}

