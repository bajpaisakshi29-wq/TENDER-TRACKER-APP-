const AI_ANALYZABLE_DOC_KEYS = ['bank_guarantee_copy','test_report','inspection_report','paper_file'];
function renderDocuments(t){
  t.documents = t.documents || {};
  t.documentInsights = t.documentInsights || {};
  const fixed = fixedDocList(t);
  const dispatchDocs = t.dispatchDocsSelected||[];
  function row(key,label){
    const doc = t.documents[key];
    const analyzable = doc && AI_ANALYZABLE_DOC_KEYS.includes(key);
    const insight = t.documentInsights[key];
    return `<div class="doc-row">
      <div class="doc-dot ${doc?'uploaded':'pending'}"></div>
      <div class="doc-info">
        <div class="doc-name">${escapeHtml(label)}</div>
        <div class="doc-meta">${doc ? `${escapeHtml(doc.fileName)} — uploaded by ${escapeHtml(doc.uploadedBy)}, ${formatDateTime(doc.uploadedAt)}` : 'Pending upload'}</div>
        ${doc && doc.mime && doc.mime.startsWith('image/') ? `<img src="${doc.dataUrl}" style="max-width:140px;border-radius:6px;margin-top:6px;">` : ''}
        ${doc ? `<a href="${doc.dataUrl}" download="${escapeHtml(doc.fileName)}" style="font-size:12px;">Download</a>` : ''}
        ${analyzable ? renderInsightArea(t, key, insight) : ''}
      </div>
      <label class="file-input-label">${doc?'Replace':'Upload'}<input type="file" class="docFileInput" data-dockey="${key}" data-doclabel="${escapeHtml(label)}" style="display:none;"></label>
    </div>`;
  }
  let html = `<div class="card">`;
  if(fixed.length===0 && dispatchDocs.length===0){
    html += `<p style="opacity:.6;font-size:13px;">Document requirements will appear here as you move through the workflow (e.g. once verification type or bank guarantee is set).</p>`;
  }
  fixed.forEach(d=> html += row(d.key, d.label));
  dispatchDocs.forEach(d=> html += row('dispatch:'+d, d));
  html += `</div>`;
  return html;
}
function bindDocuments(t){
  document.querySelectorAll('.docFileInput').forEach(inp=>{
    inp.onchange = async ()=>{
      const file = inp.files[0];
      if(!file) return;
      toast('Uploading…');
      const key = inp.dataset.dockey, label = inp.dataset.doclabel;
      const stored = await fileToStoredDoc(file);
      const hadBefore = !!t.documents[key];
      t.documents[key] = stored;
      logHistory(t, label, hadBefore?'previous file':'pending', stored.fileName);
      await saveTender(t);
      toast('Uploaded'); render();
    };
  });
  document.querySelectorAll('[data-analyze]').forEach(b=>{
    b.onclick = ()=> analyzeDocument(t, b.dataset.analyze);
  });
  document.querySelectorAll('[data-reanalyze]').forEach(b=>{
    b.onclick = ()=> analyzeDocument(t, b.dataset.reanalyze);
  });
  document.querySelectorAll('[data-chip]').forEach(chip=>{
    chip.onclick = ()=>{
      const el = document.getElementById('hl-'+chip.dataset.chip.replace(':','-'));
      if(el) el.classList.toggle('open');
