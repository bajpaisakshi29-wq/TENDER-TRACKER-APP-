<script>
const SUPABASE_URL = 'https://cuvdoxtobpmaenhqttta.supabase.co';
const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImN1dmRveHRvYnBtYWVuaHF0dHRhIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODMzMzUxNTksImV4cCI6MjA5ODkxMTE1OX0.QxrPpVjQK72yQGlJErGJNJKNxZwO7ydcnubt_e97dV4';
const sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
/* ============ CONSTANTS ============ */
const STAGES = [
  {key:'order_received', label:'Order received'},
  {key:'verification_setup', label:'Bank guarantee / verification'},
  {key:'sample_prep', label:'Sample prep'},
  {key:'sample_dispatch', label:'Sample dispatch'},
  {key:'verification_result', label:'Verification result'},
  {key:'production', label:'Production'},
  {key:'pre_dispatch', label:'Pre-dispatch checks'},
  {key:'dispatched', label:'Dispatched'},
  {key:'payment_followup', label:'Payment follow-up'},
  {key:'archived', label:'Archived'}
];
const DEFAULT_DOC_OPTIONS = ['Invoice','Packing list','Certificate of origin','Test / inspection certificate','Bank guarantee copy'];

/* ============ STATE ============ */
let state = {
  view:'loading', // loading | login | signup | waiting | dashboard | detail | admin
  currentUser: null,
  users: [],
  tenders: [],
  activeTenderId: null,
  activeTab: 'workflow',
  authError: '',
  theme: 'light'
};

function toast(msg){
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'), 2200);
}

/* ============ STORAGE HELPERS (Supabase) ============ */

async function loadAllUsers(){
  const { data, error } = await sb.from('profiles').select('*');
  if(error){ console.error(error); return []; }
  return data.map(p => ({ id:p.id, name:p.name, email:p.email, role:p.role, status:p.status, theme:p.theme, phone_number:p.phone_number, createdAt:p.created_at }));
}

function saveUser(u){
  return sb.from('profiles').update({ name:u.name, role:u.role, status:u.status, theme:u.theme, onboarded:u.onboarded }).eq('id', u.id);
}
async function loadAllTenders(){
  const { data, error } = await sb.from('tenders').select('*').order('created_at', { ascending:false });
  if(error){ console.error(error); return []; }
  return data.map(row => ({
    ...row.data, id: row.id, name: row.name, archived: row.archived, createdAt: row.created_at,
    history: row.data.history || [], documents: row.data.documents || {}, chatMessages: row.data.chatMessages || []
  }));
}
async function saveTender(t){
  const { id, name, archived, createdAt, ...rest } = t;
  const { error } = await sb.from('tenders').upsert({ id, name, archived: !!archived, data: rest });
  if(error){
    console.error(error);
    state.offlineQueue = state.offlineQueue || [];
    if(!state.offlineQueue.includes(t.id)) state.offlineQueue.push(t.id);
    renderNetBanner();
    return false;
  }
  return true;
