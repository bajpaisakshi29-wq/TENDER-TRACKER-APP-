/* ============ AI DOCUMENT INSIGHTS ============
   In production this calls a Supabase edge function `analyze-document`, which fetches the
   file from the `tender-documents` bucket and sends it to the Anthropic API
   (model: claude-sonnet-4-6) with the ANTHROPIC_API_KEY held server-side as a secret,
   never exposed to the frontend. This client-side stub mimics that contract so the UI can be
   wired up now and swapped for the real edge-function call later without changing the UI code. */
function renderInsightArea(t, key, insight){
  if(!insight){
    return `<div style="margin-top:6px;">
      <p style="opacity:.6;font-size:11.5px;margin:4px 0 6px;">Get an AI summary of this document's key terms and deadlines.</p>
      <button class="btn btn-ghost btn-sm ai-insight-btn" data-analyze="${key}">✨ Analyze with AI</button>
    </div>`;
  }
  if(insight.loading){
    return `<div class="insight-panel">Reading document…</div>`;
  }
  const sevClass = {high:'high', medium:'medium', low:'low'};
  return `<div class="insight-panel">
    <div class="insight-summary">${escapeHtml(insight.summary)}</div>
    ${insight.highlights.map((h,i)=>`
      <span class="highlight-chip ${sevClass[h.severity]||'low'}" data-chip="${key}:${i}">${h.type.replace('_',' ')}</span>
      <div class="highlight-detail" id="hl-${key}-${i}">
        <div style="margin-bottom:6px;">${escapeHtml(h.text)}</div>
        <div style="opacity:.7;margin-bottom:8px;">${escapeHtml(h.explanation)}</div>
        <button class="btn btn-ghost btn-sm" data-addspec="${key}:${i}">+ Add to specifications</button>
      </div>`).join('')}
    <div style="margin-top:8px;"><button class="btn btn-ghost btn-sm" data-reanalyze="${key}">Re-analyze</button></div>
  </div>`;
}
async function analyzeDocument(t, key){
  // STUB — replace with a real call to the `analyze-document` Supabase edge function.
  t.documentInsights = t.documentInsights || {};
  t.documentInsights[key] = {loading:true};
  render();
  await new Promise(r=>setTimeout(r, 1100));
