function dayOfYear(){ const now = new Date(); const start = new Date(now.getFullYear(),0,0); return Math.floor((now-start)/86400000); }
function getTodayQuote(){ return GITA_QUOTES[dayOfYear() % GITA_QUOTES.length]; }
function toggleQuotePopover(){
  const wrap = document.getElementById('quotePopoverWrap');
  if(!wrap) return;
  if(wrap.innerHTML){ wrap.innerHTML=''; return; }
  const q = getTodayQuote();
  const bookmarks = state.bookmarksCache || [];
  const already = bookmarks.some(b=>b.text===q.text);
  wrap.innerHTML = `<div class="quote-popover">
    <div class="verse">"${escapeHtml(q.text)}"</div>
    <div class="meaning">${escapeHtml(q.meaning)}</div>
    <button class="bookmark-btn" id="bookmarkBtn">${already?'★ Bookmarked':'☆ Bookmark'}</button>
  </div>`;
  document.getElementById('bookmarkBtn').onclick = async ()=>{
    const existing = (state.bookmarksCache||[]).find(b=>b.text===q.text);
    if(existing){
      await sb.from('bookmarks').delete().eq('id', existing.bookmarkId);
    } else {
      await sb.from('bookmarks').insert({ user_id: state.currentUser.id, quote: q });
    }
    state.bookmarksCache = await loadBookmarks();
    toggleQuotePopover(); toggleQuotePopover();
  };
}

/* ============ PERSONAL SPACE ("Your day") ============ */


async function loadTodos(){
  const { data, error } = await sb.from('todos').select('*').eq('user_id', state.currentUser.id).order('created_at', { ascending:true });
  if(error){ console.error(error); return []; }
  return data.map(r => ({ id:r.id, text:r.text, reminder:r.reminder, done:r.done }));
}
async function loadBookmarks(){
  const { data, error } = await sb.from('bookmarks').select('*').eq('user_id', state.currentUser.id).order('created_at',{ascending:false});
  if(error){ console.error(error); return []; }
  return data.map(r => ({ ...r.quote, savedAt:r.created_at, bookmarkId:r.id }));
}

function renderPersonal(){
  const todos = state.todosCache || [];
  const bookmarks = state.bookmarksCache || [];
  return `
  <h2 class="serif" style="margin-top:0;">Your day</h2>
  <div class="card" style="margin-bottom:20px;">
    <div style="display:flex;gap:8px;margin-bottom:14px;">
      <input type="text" id="newTodoText" placeholder="Add a to-do">
      <input type="text" id="newTodoReminder" placeholder="Reminder (optional, e.g. 3pm)" style="max-width:200px;">
      <button class="btn btn-primary btn-sm" id="addTodoBtn">Add</button>
    </div>
    ${todos.length===0 ? `<div class="empty-state" style="padding:30px 10px;"><div class="emoji">☀️</div><h3>Nothing on your plate yet</h3><p>Add your first to-do above.</p></div>` :
      todos.map(td=>`
      <div class="todo-row ${td.done?'done':''}">
        <input type="checkbox" data-todo="${td.id}" ${td.done?'checked':''}>
        <span class="todo-text">${escapeHtml(td.text)}${td.reminder?` <span style="opacity:.5;font-size:11.5px;">(${escapeHtml(td.reminder)})</span>`:''}</span>
        <button class="btn btn-ghost btn-sm" data-deltodo="${td.id}">Remove</button>
      </div>`).join('')}
  </div>

  <h3 class="serif" style="margin:0 0 10px;">Bookmarked verses</h3>
  <div class="card" style="margin-bottom:20px;">
    ${bookmarks.length===0 ? `<p style="opacity:.6;font-size:13px;">No bookmarked verses yet — tap the daily quote in the header and bookmark one you like.</p>` :
      bookmarks.map(b=>`<div class="hist-row"><div class="serif" style="font-style:italic;">"${escapeHtml(b.text)}"</div><div style="font-size:12px;opacity:.65;margin-top:4px;">${escapeHtml(b.meaning)}</div></div>`).join('')}
  </div>

  <div class="card">
    <div class="toggle-row">
      <span>Show daily quote in header</span>
      <input type="checkbox" id="quoteToggle" ${state.currentUser.dailyQuoteEnabled!==false?'checked':''}>
    </div>
    <div class="toggle-row">
      <span>WhatsApp number (for reminders)</span>
      <input type="text" id="phoneInput" value="${state.currentUser.phone_number||''}" placeholder="+91 98765 43210" style="max-width:180px;">
    </div>
    <button class="btn btn-ghost btn-sm" id="savePhoneBtn" style="margin-top:8px;">Save number</button>
  </div>
  `;
}
function bindPersonal(){
  document.getElementById('addTodoBtn').onclick = async ()=>{
    const text = document.getElementById('newTodoText').value.trim();
    const reminder = document.getElementById('newTodoReminder').value.trim();
    if(!text) return;
    await sb.from('todos').insert({ user_id: state.currentUser.id, text, reminder, done:false });
    state.todosCache = await loadTodos(); render();
  };
  document.querySelectorAll('[data-todo]').forEach(cb=>{
    cb.onchange = async ()=>{
      await sb.from('todos').update({ done: cb.checked }).eq('id', cb.dataset.todo);
      state.todosCache = await loadTodos(); render();
    };
  });
  document.querySelectorAll('[data-deltodo]').forEach(b=>{
    b.onclick = async ()=>{
      await sb.from('todos').delete().eq('id', b.dataset.deltodo);
      state.todosCache = await loadTodos(); render();
    };
  });
  const qt = document.getElementById('quoteToggle');
  if(qt) qt.onchange = async ()=>{
    state.currentUser.dailyQuoteEnabled = qt.checked;
    await saveUser(state.currentUser);
    render();
  };
  const savePhone = document.getElementById('savePhoneBtn');
  if(savePhone) savePhone.onclick = async ()=>{
    const phone = document.getElementById('phoneInput').value.trim();
    await sb.from('profiles').update({ phone_number: phone }).eq('id', state.currentUser.id);
    state.currentUser.phone_number = phone
    toast('Number saved');
  };
}
/* ============ UTILS ============ */
function escapeHtml(s){ return (s||'').replace(/[&<>"']/g, c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
function formatDate(d){ if(!d) return '—'; const dt=new Date(d); return dt.toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'}); }
function formatDateTime(d){ const dt=new Date(d); return dt.toLocaleString('en-GB',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'}); }

init();
