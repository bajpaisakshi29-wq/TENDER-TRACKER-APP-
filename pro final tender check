/* ============ REMINDERS ENGINE ============
   Every rule below corresponds to a step in the tender workflow. Reminders are computed live
   from tender state; snooze state is persisted per tender+type in the `reminder_state` table
   in Supabase. sendEmail()/sendWhatsApp() are intentionally stubbed — wire in a real provider
   (e.g. Resend/Twilio) later without touching any of the UI code below. */
function reminderKey(tenderId, type){ return tenderId+'__'+type; }

async function loadReminderCache(){
  const { data, error } = await sb.from('reminder_state').select('*');
  if(error){ console.error(error); state.reminderCache = {}; return; }
  const cache = {};
  data.forEach(r => { cache[r.key] = { snoozedUntil: r.snoozed_until, snoozeCount: r.snooze_count }; });
  state.reminderCache = cache;
}

function reminderRulesForTender(t){
  const rules = [];
  if(t.archived) return rules;
  if(t.currentStage===1){
    if(t.verificationType==='inspection' && !t.inspectionContacted) rules.push({type:'inspection_contact', message:'Contact the inspection officer'});
    if(t.bankGuaranteeApplicable===true && !t.bankGuaranteeSubmitted) rules.push({type:'bank_guarantee', message:'Submit the bank guarantee', adminAlso:true});
  }
  if(t.currentStage===2 && !t.samplePrepDone) rules.push({type:'sample_prep', message:'Complete sample prep'});
  if(t.currentStage===3 && !t.sampleDeliveryConfirmed) rules.push({type:'sample_dispatch', message:'Confirm sample delivery'});
  if(t.currentStage===5) rules.push({type:'production', message:'Post a production update'});
  if(t.currentStage===6 && t.dispatchDate){
    const daysLeft = daysBetween(new Date(), new Date(t.dispatchDate));
    if(t.twentyDayCheck===null && daysLeft<=20) rules.push({type:'predispatch_20', message:'20-day dispatch checkpoint due'});
    else if(t.fiveDayCheck===null && daysLeft<=5) rules.push({type:'predispatch_5', message:'5-day dispatch checkpoint due'});
  }
  if(t.currentStage===8 && !t.paid) rules.push({type:'payment_followup', message:'Follow up on payment'});
  return rules;
}

function computeDueReminders(){
  const cache = state.reminderCache || {};
  const now = Date.now();
  const list = [];
  (state.tenders||[]).forEach(t=>{
    reminderRulesForTender(t).forEach(r=>{
      const key = reminderKey(t.id, r.type);
      const st = cache[key];
      if(st && st.snoozedUntil && now < st.snoozedUntil) return;
      list.push({
        key, tenderId:t.id, tenderName:t.name, type:r.type, message:r.message,
        adminAlso: !!r.adminAlso, snoozeCount: st ? (st.snoozeCount||0) : 0,
        escalated: st ? (st.snoozeCount||0) >= 3 : false
      });
    });
  });
  return list;
}

async function sendEmail(to, subject, body){
  if(!to) return;
  try{
    const { error } = await sb.functions.invoke('send-reminder', {
      body: { to_email: to, subject, message: body }
    });
    if(error) console.error('sendEmail failed', error);
  }catch(e){ console.error('sendEmail failed', e); }
}
async function sendWhatsApp(to_phone, message){
  if(!to_phone) return;
  try{
    const { error } = await sb.functions.invoke('send-reminder', {
      body: { to_phone, message }
    });
    if(error) console.error('sendWhatsApp failed', error);
  }catch(e){ console.error('sendWhatsApp failed', e); }
}

  function escalateReminder(rem){
  const admins = (state.users||[]).filter(u=>u.role==='owner'||u.role==='admin');
  admins.forEach(a=>{
    sendEmail(a.email, `Needs attention: ${rem.tenderName}`, rem.message);
    if(a.phone_number) sendWhatsApp(a.phone_number, `Needs attention: ${rem.tenderName} — ${rem.message}`);
  });
  toast('Snoozed 3x without action — admins notified');
}
async function snoozeReminder(rem, hours){
  if(!rem) return;
  state.reminderCache = state.reminderCache || {};
  const cur = state.reminderCache[rem.key] || {snoozeCount:0};
  const newCount = (cur.snoozeCount||0) + 1;
  const entry = {snoozedUntil: Date.now() + hours*3600*1000, snoozeCount: newCount};
  state.reminderCache[rem.key] = entry;
  await sb.from('reminder_state').upsert({ key: rem.key, snoozed_until: entry.snoozedUntil, snooze_count: newCount });
  if(newCount===3) escalateReminder(rem);
  renderBell();
  render();
}
