/* ============ APP SHELL ============ */
function playNotificationSound(){
  try{
    const ctx = new (window.AudioContext || window.webkitAudioContext)();
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.connect(gain); gain.connect(ctx.destination);
    osc.frequency.value = 880;
    gain.gain.setValueAtTime(0.15, ctx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.4);
    osc.start(); osc.stop(ctx.currentTime + 0.4);
  }catch(e){ console.warn('Sound failed', e); }
}

function renderShell(){
  const u = state.currentUser;
  const isAdmin = u.role==='owner'||u.role==='admin';
  const reminders = computeDueReminders();
  return `
  <div class="app">
    <div id="netBannerWrap"></div>
    <header class="topbar">
      <div class="brand">
        ${logoImg(state.theme==='dark' ? 'logo-invert' : '')}
        <div class="word"><span class="name">Order tracker</span><span class="tag">Productivity with AGS</span></div>
      </div>
      <div class="top-right">
        ${u.dailyQuoteEnabled!==false ? `<div class="quote-line" id="quoteLine">${escapeHtml(getTodayQuote().text)}</div>` : ''}
        <button class="icon-btn" id="helpBtn" title="Help / walkthrough">?</button>
        <div class="bell-wrap">
          <button class="icon-btn" id="bellBtn" title="Reminders">🔔${reminders.length ? '<span class="bell-dot"></span>' : ''}</button>
          <div id="bellDropdownWrap"></div>
        </div>
        <button class="icon-btn" id="themeToggle" title="Toggle theme">${state.theme==='dark'?'☀':'☾'}</button>
        <div class="avatar" title="${u.name}">${u.name.split(' ').map(p=>p[0]).slice(0,2).join('').toUpperCase()}</div>
        <button class="btn btn-ghost btn-sm" id="logoutBtn">Sign out</button>
      </div>
    </header>
    <nav class="nav-tabs">
      <button data-nav="dashboard" class="${state.view==='dashboard'?'active':''}">Dashboard</button>
      <button data-nav="archive" class="${state.view==='archive'?'active':''}">Archive</button>
      <button data-nav="personal" class="${state.view==='personal'?'active':''}">Your day</button>
      ${isAdmin ? `<button data-nav="admin" class="${state.view==='admin'?'active':''}">Admin</button>` : ''}
    </nav>
    <main id="mainArea"></main>
    <div id="quotePopoverWrap"></div>
    <div id="onboardWrap"></div>
  </div>`;
}
async function notifyNewReminders(currentReminders){
  state.notifiedReminderKeys = state.notifiedReminderKeys || {};
  const isAdmin = state.currentUser.role==='owner'||state.currentUser.role==='admin';
  let hasNew = false;
  for(const r of currentReminders){
    if(state.notifiedReminderKeys[r.key]) continue;
    state.notifiedReminderKeys[r.key] = true;
    hasNew = true;
    if(isAdmin || r.adminAlso){
      if(state.currentUser.email) sendEmail(state.currentUser.email, `Reminder: ${r.tenderName}`, r.message);
      if(state.currentUser.phone_number) sendWhatsApp(state.currentUser.phone_number, `${r.tenderName} — ${r.message}`);
    }
  }
  if(hasNew) playNotificationSound();
}
function bindShell(){
  document.getElementById('themeToggle').onclick = toggleTheme;
  document.getElementById('logoutBtn').onclick = handleLogout;
  document.getElementById('helpBtn').onclick = ()=>{ state.onboardStep = 0; state.showOnboarding = true; render(); };
  document.getElementById('bellBtn').onclick = (e)=>{ e.stopPropagation(); state.bellOpen = !state.bellOpen; renderBell(); };
  renderNetBanner();
  renderBell();
  if(!state.currentUser.onboarded && !state.onboardShownThisSession){
    state.onboardShownThisSession = true;
    state.showOnboarding = true; state.onboardStep = 0;
  }
  if(state.showOnboarding) renderOnboarding();
  document.querySelectorAll('[data-nav]').forEach(b=>{
    b.onclick = async ()=>{
      const nav = b.dataset.nav;
      if(nav==='dashboard'){ state.view='dashboard'; }
      if(nav==='archive'){ state.view='archive'; }
      if(nav==='personal'){ state.view='personal'; state.todosCache = await loadTodos(); state.bookmarksCache = await loadBookmarks(); }
      if(nav==='admin'){ state.view='admin'; state.users = await loadAllUsers(); }
      render();
    };
  });
  const qLine = document.getElementById('quoteLine');
  if(qLine) qLine.onclick = ()=> toggleQuotePopover();
  const main = document.getElementById('mainArea');
  if(state.view==='dashboard') { main.innerHTML = renderDashboard(false); bindDashboard(); }
  else if(state.view==='archive') { main.innerHTML = renderDashboard(true); bindDashboard(); }
  else if(state.view==='detail') { main.innerHTML = renderDetail(); bindDetail(); }
  else if(state.view==='admin') { main.innerHTML = renderAdmin(); bindAdmin(); }
  else if(state.view==='personal') { main.innerHTML = renderPersonal(); bindPersonal(); }
  else { main.innerHTML = renderDashboard(false); bindDashboard(); }
}

/* ============ DASHBOARD ============ */
function renderDashboard(archiveMode){
  const list = state.tenders.filter(t=> archiveMode ? t.archived : !t.archived);
  return `
  <div class="dash-header">
    <h2 class="serif" style="margin:0;">${archiveMode?'Archive':'Tenders'}</h2>
    <div style="display:flex;gap:8px;">
      ${state.tenders.length ? `<button class="btn btn-ghost btn-sm" id="csvExportBtn">Export CSV</button>` : ''}
      ${!archiveMode ? `<button class="btn btn-primary" id="newTenderBtn">+ New tender</button>` : ''}
    </div>
  </div>
  ${list.length===0 ? renderEmpty(archiveMode) : `<div class="grid">${list.map(cardHtml).join('')}</div>`}
  `;
}
function renderEmpty(archiveMode){
  if(archiveMode){
    return `<div class="empty-state"><div class="emoji">🗂️</div><h3>No archived tenders yet</h3><p>Completed tenders will show up here once archived.</p></div>`;
  }
  return `<div class="empty-state"><div class="emoji">📓</div><h3>No notebooks yet</h3><p>Create your first tender to start tracking it.</p><button class="btn btn-primary" id="emptyCreateBtn">+ Create tender</button></div>`;
}
function cardHtml(t){
  const status = computeStatus(t);
  const overdueFlag = status==='overdue' ? 'overdue-flag' : '';
  const stageIdx = t.currentStage;
  const segs = STAGES.map((s,i)=>`<div class="stage-seg ${i<=stageIdx?'done':''}"></div>`).join('');
  return `
  <div class="tender-card ${overdueFlag}" data-open="${t.id}">
    <div class="tname">${escapeHtml(t.name)}</div>
    <div class="tdate">Order received ${formatDate(t.orderDate)}</div>
    <span class="badge ${status}">${statusLabel(status)}</span>
    <div class="stage-bar">${segs}</div>
  </div>`;
}
function bindDashboard(){
  const nb = document.getElementById('newTenderBtn'); if(nb) nb.onclick = openCreateTenderPrompt;
  const eb = document.getElementById('emptyCreateBtn'); if(eb) eb.onclick = openCreateTenderPrompt;
  const cb = document.getElementById('csvExportBtn'); if(cb) cb.onclick = exportTendersCSV;
  document.querySelectorAll('[data-open]').forEach(el=>{
    el.onclick = ()=>{ state.activeTenderId = el.dataset.open; state.view='detail'; state.activeTab='workflow'; render(); };
  });
}
function openCreateTenderPrompt(){
  const name = prompt('Tender name:');
  if(!name) return;
  const date = prompt('Order received date (YYYY-MM-DD):', new Date().toISOString().slice(0,10));
  if(!date) return;
  createTender(name.trim(), date);
}

/* ============ DETAIL / WORKFLOW ============ */
function isAdminUser(){
  return state.currentUser && (state.currentUser.role==='owner' || state.currentUser.role==='admin');
}
function renderDetail(){
  const t = findTender(state.activeTenderId);
  if(!t) return `<p>Tender not found.</p>`;
  const status = computeStatus(t);
  return `
  <div class="back-link" id="backToDash">&larr; Back to tenders</div>
  <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;flex-wrap:wrap;">
    <h2 class="serif" style="margin:0 0 4px;">${escapeHtml(t.name)}</h2>
    <div style="display:flex;gap:8px;">
      <button class="btn btn-ghost btn-sm" id="pdfExportBtn">Export PDF</button>
      ${isAdminUser() ? `<button class="btn btn-danger btn-sm" id="deleteTenderBtn">Delete tender</button>` : ''}
    </div>
  </div>
  <div style="opacity:.6;font-size:13px;margin-bottom:18px;">Order received ${formatDate(t.orderDate)} &nbsp;•&nbsp; <span class="badge ${status}">${statusLabel(status)}</span></div>

  <div class="stage-tracker">
    ${STAGES.map((s,i)=>`<div class="stage-step ${i===t.currentStage?'current':''}">${s.label}</div>`).join('')}
  </div>

  <div class="status-grid">
    ${statusCardHtml('Bank guarantee', t.bankGuaranteeApplicable===false?'Not applicable':(t.bankGuaranteeSubmitted?'Submitted':'Pending'), t.bankGuaranteeApplicable===false?'on-track':(t.bankGuaranteeSubmitted?'on-track':'due-soon'))}
    ${statusCardHtml('Verification', t.verificationResult ? (t.verificationResult==='pass'?'Passed':'Failed') : (t.verificationType==='inspection'?(t.inspectionContacted?'Contacted':'Awaiting contact'):(t.verificationType==='test'?'Awaiting result':'Not set')), t.verificationResult==='pass'?'on-track':(t.verificationResult==='fail'?'overdue':'due-soon'))}
    ${statusCardHtml('Sample', t.sampleDeliveryConfirmed?'Delivered':(t.sampleDispatched?'Dispatched':(t.samplePrepDone?'Prepped':'Pending')), t.sampleDeliveryConfirmed?'on-track':'due-soon')}
    ${statusCardHtml('Production', t.productionType ? (t.productionType==='in-house'?'In-house':'Outsourced') : 'Not started', t.productionType?'on-track':'due-soon')}
    ${statusCardHtml('Dispatch', t.dispatched?'Dispatched':(t.dispatchDate?('Target '+formatDate(t.dispatchDate)):'Not scheduled'), t.dispatched?'on-track':status)}
  </div>

  <div class="tabs">
    <button data-tab="workflow" class="${state.activeTab==='workflow'?'active':''}">Workflow</button>
    <button data-tab="specs" class="${state.activeTab==='specs'?'active':''}">Specifications</button>
    <button data-tab="documents" class="${state.activeTab==='documents'?'active':''}">Documents</button>
    <button data-tab="chat" class="${state.activeTab==='chat'?'active':''}">Chat</button>
    <button data-tab="history" class="${state.activeTab==='history'?'active':''}">History</button>
  </div>
  <div id="tabBody">${renderTabBody(t)}</div>
  `;
}
function statusCardHtml(label, value, tint){
  return `<div class="status-card tint ${tint}"><div style="font-weight:600;margin-bottom:4px;">${label}</div><div>${value}</div></div>`;
}
function renderTabBody(t){
  if(state.activeTab==='workflow') return renderWorkflow(t);
  if(state.activeTab==='specs') return renderSpecs(t);
  if(state.activeTab==='documents') return renderDocuments(t);
  if(state.activeTab==='chat') return renderChat(t);
  if(state.activeTab==='history') return renderHistoryTab(t);
}

function renderWorkflow(t){
  const stage = t.currentStage;
  let html = '<div class="card">';
  if(stage===0){
    html += `<p>Order logged on ${formatDate(t.orderDate)}.</p>
    <button class="btn btn-primary" data-action="advance1">Continue to verification setup</button>`;
  } else if(stage===1){
    html += `<div class="field"><label class="field-label">Is a bank guarantee applicable?</label>
      <div class="radio-group">
        <div class="radio-opt ${t.bankGuaranteeApplicable===true?'sel':''}" data-set="bgApplicable" data-val="true">Yes</div>
        <div class="radio-opt ${t.bankGuaranteeApplicable===false?'sel':''}" data-set="bgApplicable" data-val="false">No</div>
      </div></div>
      <div class="field"><label class="field-label">Verification type</label>
      <div class="radio-group">
        <div class="radio-opt ${t.verificationType==='test'?'sel':''}" data-set="verType" data-val="test">Test report</div>
        <div class="radio-opt ${t.verificationType==='inspection'?'sel':''}" data-set="verType" data-val="inspection">Inspection</div>
      </div></div>
      ${t.verificationType==='inspection' ? `<div class="checkline"><input type="checkbox" id="inspContact" ${t.inspectionContacted?'checked':''}><label for="inspContact">Inspection officer contacted</label></div>` : ''}
      ${t.bankGuaranteeApplicable===true ? `<div class="checkline"><input type="checkbox" id="bgSubmitted" ${t.bankGuaranteeSubmitted?'checked':''}><label for="bgSubmitted">Bank guarantee submitted</label></div>` : ''}
      <button class="btn btn-primary" data-action="advance2" style="margin-top:10px;" ${canAdvanceStage2(t)?'':'disabled'}>Continue to sample prep</button>`;
  } else if(stage===2){
    html += `<div class="checkline"><input type="checkbox" id="samplePrep" ${t.samplePrepDone?'checked':''}><label for="samplePrep">Sample prep done</label></div>
    <button class="btn btn-primary" data-action="advance3" style="margin-top:10px;" ${t.samplePrepDone?'':'disabled'}>Continue to sample dispatch</button>`;
  } else if(stage===3){
    html += `<div class="checkline"><input type="checkbox" id="sampleDispatched" ${t.sampleDispatched?'checked':''}><label for="sampleDispatched">Sample dispatched</label></div>
    <div class="checkline"><input type="checkbox" id="deliveryConfirmed" ${t.sampleDeliveryConfirmed?'checked':''}><label for="deliveryConfirmed">Delivery confirmed</label></div>
    <button class="btn btn-primary" data-action="advance4" style="margin-top:10px;" ${t.sampleDispatched&&t.sampleDeliveryConfirmed?'':'disabled'}>Continue to verification result</button>`;
  } else if(stage===4){
    html += `<div class="field"><label class="field-label">Verification result</label>
    <div class="radio-group">
      <div class="radio-opt ${t.verificationResult==='pass'?'sel':''}" data-set="verResult" data-val="pass">Pass</div>
      <div class="radio-opt ${t.verificationResult==='fail'?'sel':''}" data-set="verResult" data-val="fail">Fail</div>
    </div></div>
    ${t.verificationResult==='fail' ? `<p style="font-size:13px;opacity:.7;">A failed result sends this tender back to the inspection-contact step.</p>` : ''}
    <button class="btn btn-primary" data-action="advance5" style="margin-top:10px;" ${t.verificationResult?'':'disabled'}>Continue</button>`;
  } else if(stage===5){
    html += `<div class="field"><label class="field-label">Production</label>
    <div class="radio-group">
      <div class="radio-opt ${t.productionType==='outsourced'?'sel':''}" data-set="prodType" data-val="outsourced">Outsourced</div>
      <div class="radio-opt ${t.productionType==='in-house'?'sel':''}" data-set="prodType" data-val="in-house">In-house</div>
    </div></div>
    <div class="field"><label class="field-label">Add a documentation update</label>
    <textarea id="prodNote" rows="2" placeholder="e.g. Uppers cutting complete, stitching in progress"></textarea>
    <button class="btn btn-ghost btn-sm" style="margin-top:6px;" data-action="addProdNote">Add note</button></div>
    ${t.productionNotes.length ? `<div style="margin-bottom:12px;">${t.productionNotes.slice().reverse().map(n=>`<div style="font-size:12.5px;opacity:.75;padding:4px 0;border-top:1px solid var(--border-light);">${escapeHtml(n.text)} — <span style="opacity:.6;">${formatDateTime(n.timestamp)}</span></div>`).join('')}</div>` : ''}
    <button class="btn btn-primary" data-action="advance6" ${t.productionType?'':'disabled'}>Continue to pre-dispatch checks</button>`;
  } else if(stage===6){
    html += renderPreDispatch(t);
  } else if(stage===7){
    html += `<p>Dispatch documents complete. Ready to mark as dispatched.</p>
    <button class="btn btn-primary" data-action="markDispatched">Mark dispatched</button>`;
  } else if(stage===8){
    html += `<div class="checkline"><input type="checkbox" id="paid" ${t.paid?'checked':''}><label for="paid">Payment received</label></div>
    <button class="btn btn-primary" data-action="archiveTender" style="margin-top:10px;" ${t.paid?'':'disabled'}>Archive tender</button>`;
  } else if(stage===9){
    html += `<p>This tender is archived. It stays visible here and in the archive view.</p>`;
  }
  html += '</div>';
  return html;
}
function canAdvanceStage2(t){
  if(t.bankGuaranteeApplicable===null || !t.verificationType) return false;
  if(t.verificationType==='inspection' && !t.inspectionContacted) return false;
  if(t.bankGuaranteeApplicable===true && !t.bankGuaranteeSubmitted) return false;
  return true;
}
  function renderPreDispatch(t){
  let html = `<div class="field"><label class="field-label">Dispatch date</label><input type="date" id="dispatchDate" value="${t.dispatchDate||''}"></div>`;
  if(!t.dispatchDate) return html + `<button class="btn btn-primary" data-action="setDispatchDate">Save date</button>`;

  const dd = new Date(t.dispatchDate);
  const daysLeft = daysBetween(new Date(), dd);
  html += `<p style="font-size:12.5px;opacity:.7;">${daysLeft} day(s) until target dispatch. Extensions so far: ${t.extensionCount}</p>`;

  if(t.twentyDayCheck===null){
    html += `<div class="field"><label class="field-label">Will it be ready to dispatch in 20 days?</label>
    <div class="radio-group">
      <div class="radio-opt" data-set="twentyDayCheck" data-val="true">Yes</div>
      <div class="radio-opt" data-set="twentyDayCheck" data-val="false">No — apply for extension</div>
    </div></div>`;
    return html;
  }
  if(t.twentyDayCheck===false && !t._extensionHandled){
    html += `<div class="field"><label class="field-label">New dispatch date</label><input type="date" id="newDispatchDate"></div>
    <button class="btn btn-primary" data-action="applyExtension">Apply extension</button>`;
    return html;
  }
  if(t.fiveDayCheck===null){
    html += `<div class="checkline"><input type="checkbox" id="fiveDayCheck"><label for="fiveDayCheck">5-day checkpoint done — ready to prepare dispatch documents</label></div>
    <button class="btn btn-primary" data-action="confirmFiveDay">Confirm</button>`;
    return html;
  }
  if(t.dispatchDocsSelected.length===0){
    html += `<div class="field"><label class="field-label">Which documents are required for this dispatch?</label>
    ${DEFAULT_DOC_OPTIONS.map((d,i)=>`<div class="checkline"><input type="checkbox" class="docOpt" value="${escapeHtml(d)}" id="doc${i}"><label for="doc${i}">${d}</label></div>`).join('')}
    <div style="display:flex;gap:8px;margin-top:8px;">
      <input type="text" id="customDoc" placeholder="Add custom document">
      <button class="btn btn-ghost btn-sm" data-action="addCustomDoc">Add</button>
    </div></div>
    <button class="btn btn-primary" data-action="saveDocSelection">Generate checklist</button>`;
    return html;
  }
  t.dispatchDocsSelected.forEach(d=>{
    if(t.documents && t.documents['dispatch:'+d]) t.dispatchDocsChecklist[d] = true;
  });
  html += `<div class="field"><label class="field-label">Dispatch document checklist</label>
  ${t.dispatchDocsSelected.map((d,i)=>`<div class="checkline">
    <input type="checkbox" class="docCheck" data-doc="${escapeHtml(d)}" id="docChk${i}" ${t.dispatchDocsChecklist[d]?'checked':''}>
    <label for="docChk${i}">${escapeHtml(d)} ${t.documents && t.documents['dispatch:'+d] ? '— uploaded' : '— tick once ready, or upload it in the Documents tab'}</label>
  </div>`).join('')}
  </div>
  <div class="checkline"><input type="checkbox" id="physicalCopies" ${t.physicalCopiesSent?'checked':''}><label for="physicalCopies">Physical copies sent with shipment</label></div>
  <button class="btn btn-primary" data-action="finishPreDispatch" style="margin-top:10px;" ${allDocsChecked(t)&&t.physicalCopiesSent?'':'disabled'}>Continue to dispatched</button>`;
  return html;
}
function allDocsChecked(t){
  return t.dispatchDocsSelected.every(d=>t.dispatchDocsChecklist[d]);
}

function renderSpecs(t){
  return `<div class="card">
  ${t.specifications.length===0 ? `<p style="opacity:.6;font-size:13.5px;">No specifications added yet.</p>` : t.specifications.map(s=>`
    <div class="spec-row"><b style="min-width:140px;">${escapeHtml(s.label)}</b><span style="flex:1;">${escapeHtml(s.value)}</span>
    <button class="btn btn-ghost btn-sm" data-delspec="${s.id}">Remove</button></div>`).join('')}
  <div style="display:flex;gap:8px;margin-top:14px;">
    <input type="text" id="specLabel" placeholder="Label (e.g. Material)">
    <input type="text" id="specValue" placeholder="Value (e.g. Full-grain leather)">
    <button class="btn btn-primary btn-sm" id="addSpecBtn">Add</button>
  </div></div>`;
}

function bindDetail(){
  const t = findTender(state.activeTenderId);
  document.getElementById('backToDash').onclick = ()=>{ state.view='dashboard'; render(); };
  const pdfBtn = document.getElementById('pdfExportBtn'); if(pdfBtn) pdfBtn.onclick = ()=>exportTenderPDF(t);
  const deleteBtn = document.getElementById('deleteTenderBtn');
  if(deleteBtn) deleteBtn.onclick = async ()=>{
    const confirmed = confirm(`Are you sure you want to permanently delete "${t.name}"? This cannot be undone.`);
    if(!confirmed) return;
    const { error } = await sb.from('tenders').delete().eq('id', t.id);
    if(error){ toast('Failed to delete — try again'); console.error(error); return; }
    state.tenders = state.tenders.filter(x=>x.id!==t.id);
    state.view = 'dashboard';
    toast('Tender deleted');
    render();
  };
  document.querySelectorAll('[data-tab]').forEach(b=>{
    b.onclick = ()=>{ state.activeTab = b.dataset.tab; render(); };
  });
  bindWorkflowActions(t);
  if(state.activeTab==='specs') bindSpecs(t);
  if(state.activeTab==='documents') bindDocuments(t);
  if(state.activeTab==='chat') bindChat(t);
}
function bindSpecs(t){
  const addBtn = document.getElementById('addSpecBtn');
  if(addBtn) addBtn.onclick = async ()=>{
    const label = document.getElementById('specLabel').value.trim();
    const value = document.getElementById('specValue').value.trim();
    if(!label||!value) return;
    t.specifications.push({id:uid(), label, value});
    logHistory(t, 'specification: '+label, '', value);
    await saveTender(t); render();
  };
  document.querySelectorAll('[data-delspec]').forEach(b=>{
    b.onclick = async ()=>{
      const removed = t.specifications.find(s=>s.id===b.dataset.delspec);
      t.specifications = t.specifications.filter(s=>s.id!==b.dataset.delspec);
      if(removed) logHistory(t, 'specification: '+removed.label, removed.value, 'removed');
      await saveTender(t); render();
    };
  });
}
function bindWorkflowActions(t){
  document.querySelectorAll('[data-set]').forEach(el=>{
    el.onclick = async ()=>{
      const field = el.dataset.set, val = el.dataset.val;
      if(field==='bgApplicable'){ logHistory(t,'bank guarantee applicable', t.bankGuaranteeApplicable, val); t.bankGuaranteeApplicable = val==='true'; }
      if(field==='verType'){ logHistory(t,'verification type', t.verificationType, val); t.verificationType = val; }
      if(field==='verResult'){ logHistory(t,'verification result', t.verificationResult, val); t.verificationResult = val; }
      if(field==='prodType'){ logHistory(t,'production type', t.productionType, val); t.productionType = val; }
      if(field==='twentyDayCheck'){ logHistory(t,'20-day check', t.twentyDayCheck, val); t.twentyDayCheck = val==='true'; }
      await saveTender(t); render();
    };
  });
  const bind = (id, fn)=>{ const e=document.getElementById(id); if(e) e.onchange = fn; };
  bind('inspContact', async e=>{ logHistory(t,'inspection contacted', t.inspectionContacted, e.target.checked); t.inspectionContacted=e.target.checked; await saveTender(t); render(); });
  bind('bgSubmitted', async e=>{ logHistory(t,'bank guarantee submitted', t.bankGuaranteeSubmitted, e.target.checked); t.bankGuaranteeSubmitted=e.target.checked; await saveTender(t); render(); });
  bind('samplePrep', async e=>{ logHistory(t,'sample prep done', t.samplePrepDone, e.target.checked); t.samplePrepDone=e.target.checked; await saveTender(t); render(); });
  bind('sampleDispatched', async e=>{ logHistory(t,'sample dispatched', t.sampleDispatched, e.target.checked); t.sampleDispatched=e.target.checked; await saveTender(t); render(); });
  bind('deliveryConfirmed', async e=>{ logHistory(t,'delivery confirmed', t.sampleDeliveryConfirmed, e.target.checked); t.sampleDeliveryConfirmed=e.target.checked; await saveTender(t); render(); });
  bind('paid', async e=>{ logHistory(t,'paid', t.paid, e.target.checked); t.paid=e.target.checked; await saveTender(t); render(); });

  const actionBtn = (action, fn)=>{ const e=document.querySelector(`[data-action="${action}"]`); if(e) e.onclick = fn; };
  actionBtn('advance1', async ()=>{ t.currentStage=1; t.stageEnteredAt=new Date().toISOString(); await saveTender(t); render(); });
